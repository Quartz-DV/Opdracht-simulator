<Window x:Class="SimulatorUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimulatorUI"
        mc:Ignorable="d"
        Title="KlantBestandSimulator" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="0.3*" />
        </Grid.ColumnDefinitions>

        <Border Background="LightGray" Grid.Row="1" Grid.ColumnSpan="3"/>
        <Border Background="Silver" Grid.Row="2" Grid.ColumnSpan="3"/>
        <Border Background="Silver" Grid.Row="0" Grid.ColumnSpan="3"/>

        <Viewbox Grid.Row="0" Grid.ColumnSpan="3" HorizontalAlignment="Left" Margin="20" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="KlantBestandSimulator" FontSize="36" FontWeight="Bold" Foreground="DarkBlue"/>
                <Image Source="C:\Users\basca\HogentRepositories\Simulator\Simulator\SolutionOpdrachtSimulator\SimulatorUI\Images\Job-Profile-Search--Streamline-Freehand (1).png"
                    HorizontalAlignment="Left"
                    Height="50" 
                    Width="50" Grid.ColumnSpan="2"/>
            </StackPanel>

        </Viewbox>



        <Button x:Name="StartButton" Content="Start" FontSize="18" HorizontalAlignment="Right" Margin="10,0,0,10" VerticalAlignment="Bottom" Width="150" Grid.Row="2" Grid.Column="1" Click="StartButton_Click"/>

        <Button x:Name="SluitenButton" Content="Sluiten" FontSize="18" HorizontalAlignment="Right" Margin="10,0,0,10" VerticalAlignment="Bottom" Width="150" Grid.Row="2" Grid.Column="0" Click="SluitenButton_Click"/>




        


    </Grid>
</Window>
