<Window x:Class="SimulatorUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimulatorUI"
        mc:Ignorable="d"
        Title="KlantBestandSimulator" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="0.3*" />
        </Grid.ColumnDefinitions>

        <Border Background="GhostWhite" Grid.Row="1" Grid.ColumnSpan="3"/>
        <Border Background="LightSkyBlue" Grid.Row="2" Grid.ColumnSpan="3"/>
        <Border Background="LightSkyBlue" Grid.Row="0" Grid.ColumnSpan="3"/>
<!--Titel-->
        <Viewbox Grid.Row="0" Grid.ColumnSpan="3" HorizontalAlignment="Left" Margin="20, 0" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Image Source="Images\logo.png"
                    HorizontalAlignment="Left"
                    Height="500"
                    Width="1300"
                       />
                <Image Source="Images\Job-Profile-Search--Streamline-Freehand (1).png"
                    HorizontalAlignment="Left"
                    Height="350" 
                    Width="350" Grid.ColumnSpan="2"/>
            </StackPanel>

        </Viewbox>
        
<!--GeslachtsSelector-->
        <TextBlock x:Name="GenderTitle" Text="Geslachtsvoorkeur" FontSize="18" HorizontalAlignment="Left" Margin="50, 20" VerticalAlignment="Top" Grid.Row="1"  />
        <CheckBox x:Name="ManCheck" Content="Man" FontSize="15" HorizontalAlignment="Left" Margin="65, 50" VerticalAlignment="Top" Width="50" Grid.Row="1" Click="ManCheck_Click"/>
        <CheckBox x:Name="VrouwCheck" Content="Vrouw" FontSize="15" HorizontalAlignment="Left" Margin="65, 70, 0, 0" VerticalAlignment="Top" Width="70" Grid.Row="1" Click="VrouwCheck_Click"/>
        
<!--AantalBestandenSelector-->
        <TextBlock x:Name="AantalBestandenTitle" Text="Gewenst aantal bestanden" FontSize="18" HorizontalAlignment="Right" Margin="30, 20" VerticalAlignment="Top" Grid.Row="1"/>
        <TextBox x:Name="AantalBestandenInput" Text=" " FontSize="18" HorizontalAlignment="Right" Margin="165, 50" VerticalAlignment="Top" Width="60" Grid.Row="1"/>
        <Button x:Name="RandomAantalButton" Content="Willekeurig" FontSize="18" Background="AliceBlue" HorizontalAlignment="Right" Margin=" 50, 50" VerticalAlignment="Top" Width="100" Grid.Row="1"/>

        <!--FolderSelector-->
        <TextBlock x:Name="FolderSelectorTitle" Text="Selecteer een folder om de bestanden in op te slaan." FontSize="18" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="30, 63" Grid.Row="1" Grid.Column="0"  />
        <Button x:Name="SelectFolderButton" Content="Zoeken..." FontSize="18" Background="AliceBlue" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0, 35" Width="100" Grid.Row="1" Grid.Column="1" Click="SelectFolderButton_Click"/>
        <TextBox x:Name="SelectedFolder" Text="(Directory Path)" FontSize="18" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="30, 35" Width="530" Grid.Row="1"/>
        
<!--Start & Sluiten-->
        <Button x:Name="StartButton" Content="Start" FontSize="18" Background="AliceBlue" HorizontalAlignment="Right" Margin="10,0,0,10" VerticalAlignment="Bottom" Width="150" Grid.Row="2" Grid.Column="1" Click="StartButton_Click"/>
        <Button x:Name="AfsluitenButton" Content="Afsluiten" FontSize="18" Background="AliceBlue" HorizontalAlignment="Right" Margin="10,0,0,10" VerticalAlignment="Bottom" Width="150" Grid.Row="2" Grid.Column="0" Click="AfsluitenButton_Click"/>

    </Grid>
</Window>
